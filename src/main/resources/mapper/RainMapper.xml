<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.example.demo.mapper.RainMapper">

    <!-- ==================== 每日等级预警 ==================== -->
    <select id="getDayLevel" resultType="com.example.demo.entity.RainDayLevel">
        select a.*, b.rank, b.warning, b.meteor
        from acd_day_level_rain a
        left join acd_level_rain b
          on a.id = b.id
        where a.tjdate = (
            select max(tjdate) from acd_day_level_rain
            where tjdate <= #{today}
        )
    </select>

    <!-- ==================== 固定停车点位 ==================== -->
    <select id="getCarPlace" resultType="com.example.demo.entity.RainCarPlace">
        select *
        from acd_car_place_rain
    </select>

    <!-- ==================== 值班信息 ==================== -->
    <select id="getZhiban" resultType="com.example.demo.entity.RainZhiban">
        select *
        from acd_zhiban_rain
        where tjdate = (
            select max(tjdate) from acd_zhiban_rain
            where tjdate <= #{today}
        )
        order by tjdate
    </select>

    <!-- ==================== 施救单位 ==================== -->
    <select id="getRepair" resultType="com.example.demo.entity.RainSaveRepair">
        select *
        from acd_save_repair_rain
    </select>

    <!-- ==================== 中心对口联络机制 ==================== -->
    <select id="getLianluo" resultType="com.example.demo.entity.RainLianluo">
        select *
        from acd_lianluo_rain
    </select>

    <!-- ==================== 物资 ==================== -->
    <select id="getItems" resultType="com.example.demo.entity.RainItems">
        select *
        from acd_items_rain
    </select>

    <!-- ==================== 预警对应措施 ==================== -->
    <!-- 联表路径：acd_day_level_rain(tjdate) → acd_level_map_rain(id) → acd_level_process_rain(number) -->
    <select id="getLevelProcessByDate" resultType="com.example.demo.entity.RainLevelProcess">
        select c.number, c.measure
        from acd_day_level_rain a
        join acd_level_map_rain b
          on a.id = b.id
        join acd_level_process_rain c
          on b.number = c.number
        where a.tjdate = #{date}
        order by c.number
    </select>

</mapper>
